generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())

  sessions     Session[]
  comments     Comment[]
}

model Session {
  id        Int      @id @default(autoincrement())

  // 登录凭证，会写入浏览器 Cookie。
  // 服务器通过这个 token 判断当前是谁登录了。
  token     String   @unique

  // 当前 Session 属于哪个用户。
  userId    Int

  // Session 过期时间。
  // 超过这个时间后，需要重新登录。
  expiresAt DateTime

  createdAt DateTime @default(now())

  // 建立 Session 和 User 的关系。
  // 如果用户被删除，对应 Session 也一起删除。
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id         Int       @id @default(autoincrement())
  title      String
  excerpt    String
  content    String
  coverImage String
  author     String
  isPaid     Boolean   @default(false)
  price      Int       @default(0)
  createdAt  DateTime  @default(now())

  // 一个帖子可以有多条评论。
  comments   Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())

  // 当前评论属于哪个帖子
  postId    Int

  // 当前评论属于哪个用户
  // 这里先允许为空，是为了兼容之前已经存在的测试评论
  userId    Int?

  // 显示用用户名快照
  // 即使以后用户改昵称，旧评论也还能显示当时的名字
  username  String

  content   String
  createdAt DateTime @default(now())

  // 评论和帖子关系
  // 如果帖子被删除，下面的评论也一起删除
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 评论和用户关系
  // 如果用户被删除，评论不会强制删除，只是 userId 变为空
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}