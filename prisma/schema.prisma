generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PostType {
  WORK
  NOTICE
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())

  sessions     Session[]
  comments     Comment[]
}

model Session {
  id        Int      @id @default(autoincrement())

  // 登录凭证，会写入浏览器 Cookie。
  // 服务器通过这个 token 判断当前是谁登录了。
  token     String   @unique

  // 当前 Session 属于哪个用户。
  userId    Int

  // Session 过期时间。
  // 超过这个时间后，需要重新登录。
  expiresAt DateTime

  createdAt DateTime @default(now())

  // 建立 Session 和 User 的关系。
  // 如果用户被删除，对应 Session 也一起删除。
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id         Int       @id @default(autoincrement())

  // 帖子类型：
  // WORK   = 作品帖
  // NOTICE = 公告帖
  type       PostType  @default(WORK)

  title      String

  // 首页卡片显示的简短简介
  excerpt    String

  // 正文介绍内容，所有人都可以看到
  content    String

  // 免费预览内容。
  // 对付费作品来说，这里可以放一部分试看内容。
  previewContent String @default("")

  // 付费隐藏内容。
  // 只有购买后，或者管理员自己，才能看到。
  paidContent String @default("")

  // 作品封面图
  coverImage String

  // 下载链接。
  // 以后可以放网盘链接、文件链接等。
  downloadUrl String?

  // 下载提取码。
  // 如果不需要，可以为空。
  downloadCode String?

  // 当前先保留作者字段。
  // 以后如果永远只有你一个作者，也可以固定显示站主名。
  author     String

  // 是否是付费作品
  isPaid     Boolean   @default(false)

  // 单篇买断价格
  price      Int       @default(0)

  // 是否发布。
  // false 的时候可以作为草稿，不在前台显示。
  isPublished Boolean  @default(true)

  // 是否置顶。
  // 以后首页可以优先显示置顶作品。
  isPinned   Boolean   @default(false)

  createdAt  DateTime  @default(now())
  
  // 最后更新时间。
  // @default(now()) 用来给已有旧数据一个初始时间。
  // @updatedAt 表示以后每次更新帖子时，Prisma 会自动刷新这个时间。
  updatedAt  DateTime  @default(now()) @updatedAt

  comments   Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())

  // 当前评论属于哪个帖子
  postId    Int

  // 当前评论属于哪个用户
  // 这里先允许为空，是为了兼容之前已经存在的测试评论
  userId    Int?

  // 显示用用户名快照
  // 即使以后用户改昵称，旧评论也还能显示当时的名字
  username  String

  content   String
  createdAt DateTime @default(now())

  // 评论和帖子关系
  // 如果帖子被删除，下面的评论也一起删除
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 评论和用户关系
  // 如果用户被删除，评论不会强制删除，只是 userId 变为空
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}