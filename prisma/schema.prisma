generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}

model Post {
  id           Int       @id @default(autoincrement())
  title        String
  excerpt      String
  content      String
  coverImage   String
  author       String
  isPaid       Boolean   @default(false)
  price        Int       @default(0)
  createdAt    DateTime  @default(now())

  comments     Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  username  String
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}